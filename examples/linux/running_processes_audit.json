      "actions": [
        {
          "slug": "top-cpu",
          "name": "Top CPU processes",
          "description": "List top 20 processes by CPU usage.",
          "command": "ps aux --sort=-%cpu | head -20",
          "supported_os": [
            "linux"
          ],
          "timeout_seconds": 15,
          "risk_level": "low",
          "requires_admin": false
        },
        {
          "slug": "top-mem",
          "name": "Top memory processes",
          "description": "List top 20 processes by memory usage.",
          "command": "ps aux --sort=-%mem | head -20",
          "supported_os": [
            "linux"
          ],
          "timeout_seconds": 15,
          "risk_level": "low",
          "requires_admin": false
        },
        {
          "slug": "unique-procs",
          "name": "Unique commands",
          "description": "Show unique user/pid/command tuples (excluding grep/ps).",
          "command": "ps aux | grep -vE 'grep|ps aux' | awk '{print $1, $2, $11}' | sort -u",
          "supported_os": [
            "linux"
          ],
          "timeout_seconds": 15,
          "risk_level": "low",
          "requires_admin": false
        }
      ]
    }
