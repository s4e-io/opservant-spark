          "command": "ps aux | awk '{print $1, $2, $11}' | sort -u",
          "supported_os": [
            "darwin"
          ],
          "timeout_seconds": 15,
          "risk_level": "low",
          "requires_admin": false
        },
        {
          "slug": "grep-suspicious-names",
          "name": "Heuristic suspicious names",
          "description": "Search for common suspicious keywords in process list.",
          "command": "ps aux | grep -iE 'miner|keylog|rat|backdoor' 2>/dev/null",
